# Kronk — model to load (run `kronk catalog list` to see available IDs)
KRONK_MODELS=gemma-4-26B-A4B-it-Q8_0

# Context windows are configured per model in kronk/kronk.model_config.yaml.
# Defaults are tuned for heavier coding/debugging sessions at 32K context.

# Kronk server endpoints (defaults shown)
KRONK_WEB_API_HOST=0.0.0.0:11435
KRONK_WEB_DEBUG_HOST=0.0.0.0:8091

# Set to true to auto-update Kronk without prompting
KRONK_AUTO_UPDATE=false

# Optional: track which Gemma tuning preset was last activated with
# bash scripts/kronk_tuning_switch.sh
KRONK_TUNING_PROFILE=manual
